{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "my-lyonspride-site",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-03-29",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "my-lyonspride-site","database_id": "707041be-a96d-4051-bfcf-b1e84af9b69a",
			// Run `wrangler d1 create my-emdash-site` and paste the ID here
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "my-lyonspride-media","preview_bucket_name": "my-lyonspride-media",
		},
	],
	"observability": {
		"enabled": true,
	},
	"worker_loaders": [
		{
			"binding": "LOADER",
		},
	],
}